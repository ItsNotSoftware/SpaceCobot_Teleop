# Unreal Engine-specific files and directories

# User-specific files
SpaceCobot_Teleop/.vs/

# Compiled Object files
SpaceCobot_Teleop/**/*.slo
SpaceCobot_Teleop/**/*.lo
SpaceCobot_Teleop/**/*.o
SpaceCobot_Teleop/**/*.obj

# Precompiled Headers
SpaceCobot_Teleop/**/*.gch
SpaceCobot_Teleop/**/*.pch

# Compiled Dynamic libraries
SpaceCobot_Teleop/**/*.so
SpaceCobot_Teleop/**/*.dylib
SpaceCobot_Teleop/**/*.dll

# Fortran module files
SpaceCobot_Teleop/**/*.mod

# Compiled Static libraries
SpaceCobot_Teleop/**/*.lai
SpaceCobot_Teleop/**/*.la
SpaceCobot_Teleop/**/*.a
SpaceCobot_Teleop/**/*.lib

# Executables
SpaceCobot_Teleop/**/*.exe
SpaceCobot_Teleop/**/*.out
SpaceCobot_Teleop/**/*.app
SpaceCobot_Teleop/**/*.ipa

# These project files can be generated by the engine
SpaceCobot_Teleop/**/*.xcodeproj
SpaceCobot_Teleop/**/*.xcworkspace
SpaceCobot_Teleop/**/*.sln
SpaceCobot_Teleop/**/*.suo
SpaceCobot_Teleop/**/*.opensdf
SpaceCobot_Teleop/**/*.sdf
SpaceCobot_Teleop/**/*.VC.db
SpaceCobot_Teleop/**/*.VC.opendb

# Precompiled Assets
SpaceCobot_Teleop/SourceArt/**/*.png
SpaceCobot_Teleop/SourceArt/**/*.tga

# Binary Files
SpaceCobot_Teleop/Binaries/*
SpaceCobot_Teleop/Plugins/**/Binaries/*

# Builds
SpaceCobot_Teleop/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!SpaceCobot_Teleop/Build/*/
SpaceCobot_Teleop/Build/*/**
!SpaceCobot_Teleop/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!SpaceCobot_Teleop/Build/**/*.ico

# Built data for maps
SpaceCobot_Teleop/*_BuiltData.uasset

# Configuration files generated by the Editor
SpaceCobot_Teleop/Saved/*

# Compiled source files for the engine to use
SpaceCobot_Teleop/Intermediate/*
SpaceCobot_Teleop/Plugins/**/Intermediate/*

# Cache files for the editor to use
SpaceCobot_Teleop/DerivedDataCache/*
